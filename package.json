{
  "name": "ClawStudio",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "typecheck": "nuxt typecheck",
    "deploy": "git push origin main",
    "firebase:secrets": "firebase apphosting:secrets:set",
    "firebase:rollouts": "firebase apphosting:rollouts:list clawstudio-webapp",
    "firebase:redeploy": "firebase apphosting:rollouts:create clawstudio-webapp"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.100",
    "@iconify-json/simple-icons": "^1.2.75",
    "@nuxt/ui": "^4.6.0",
    "@nuxtjs/i18n": "^10.2.4",
    "nuxt": "^4.4.2",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "eslint": "^10.1.0",
    "typescript": "^5.6.3",
    "vue-tsc": "^3.2.6"
  },
  "packageManager": "pnpm@10.33.0"
}
